{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Turf booking information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "paid"] },
        "price": { "type": "number" },
        "advanceAmount": { "type": "number" },
        "couponCode": { "type": "string" },
        "discountAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["bkash", "nagad", "rocket"] },
        "transactionId": { "type": "string" },
        "paymentPhoneLast4": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "startTime", "endTime", "status", "price"]
    },
    "Pricing": {
      "title": "Pricing",
      "description": "Pricing configuration for time slots",
      "type": "object",
      "properties": {
        "dayType": { "type": "string", "enum": ["weekday", "weekend"] },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "price": { "type": "number" }
      },
      "required": ["dayType", "startTime", "endTime", "price"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon codes",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "discount", "isActive"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Turf bookings"
    },
    "/pricing/{pricingId}": {
      "schema": "Pricing",
      "description": "Pricing configuration"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons"
    }
  }
}
